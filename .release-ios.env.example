# App Store Connect API auth for scripts/release.sh.
#
# Copy this file to `.release-ios.env` (gitignored) and fill in the real values.
# These are IDENTIFIERS, not the credential itself — the secret is the .p8
# private key, which lives in ~/.appstoreconnect and is never committed.
#
#   cp .release-ios.env.example .release-ios.env
#   # then edit .release-ios.env with your values

export ASC_API_KEY_ID="XXXXXXXXXX"                              # App Store Connect API key ID
export ASC_API_ISSUER_ID="00000000-0000-0000-0000-000000000000"  # ASC issuer UUID
# Optional — defaults to ~/.appstoreconnect/AuthKey_<KEY_ID>.p8 :
# export ASC_API_KEY_PATH="$HOME/.appstoreconnect/AuthKey_XXXXXXXXXX.p8"
