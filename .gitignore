# Python
__pycache__/
*.pyc
.venv/
.pytest_cache/
.ruff_cache/
*.egg-info/
build/
dist/

# Env
.env
.env.local

# macOS
.DS_Store

# Xcode (project.pbxproj IS regenerated by xcodegen; ignore everything else)
ios/HermesVoice/HermesVoice.xcodeproj/xcuserdata/
ios/HermesVoice/HermesVoice.xcodeproj/project.xcworkspace/xcuserdata/
ios/HermesVoice/HermesVoice.xcodeproj/project.xcworkspace/xcshareddata/
xcuserdata/
*.xcuserstate
DerivedData/

# Hermes Voice scratch
/tmp-audio/

# Isolated agent worktrees
/.worktrees/

# Design mockups from Claude Design (local reference only, not for version control)
/Voice.zip
/Voice/

# Tailscale-issued TLS certs (never commit)
backend/certs/*.crt
backend/certs/*.key

# Signing / auth keys — APNs + App Store Connect API (.p8). These live in
# ~/.hermes-voice and ~/.appstoreconnect, but ignore the patterns anywhere
# in-tree as defense-in-depth so a stray copy never gets committed.
*.p8
AuthKey_*.p8
apns-key.p8

# Release tooling local secrets (issuer IDs / key paths), à la simmersmith
.release-ios.env

# Xcode archives / exports (release.sh writes these to /tmp, but just in case)
*.xcarchive
ios/HermesVoice/build/
