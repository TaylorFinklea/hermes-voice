# Hermes Voice backend configuration.
# Copy to .env (or export in your shell) and fill in what you have.
# If NOTHING is set, the backend auto-engages mock mode and serves canned responses.

# --- General -----------------------------------------------------------------
# Bind address. localhost is safest; use 0.0.0.0 only on trusted LAN / Tailscale.
HERMES_VOICE_HOST=127.0.0.1
HERMES_VOICE_PORT=8765

# Force mock mode (handy for iOS development without burning API calls).
# When set, real Hermes/STT/TTS are bypassed even if keys are present.
HERMES_VOICE_MOCK=0

# Optional shared-secret header. If set, requests must send X-Hermes-Voice-Token.
# HERMES_VOICE_TOKEN=

# HTTPS — if both are set, uvicorn serves TLS directly. The recommended path
# is a Tailscale-issued cert (`tailscale cert <name>.ts.net`), which gives a
# real Let's Encrypt cert that iOS trusts. Without these, the backend serves
# plain HTTP (fine for localhost / simulator).
# HERMES_VOICE_CERT=/Users/you/git/hermes-voice/backend/certs/scadrial.tailceb58.ts.net.crt
# HERMES_VOICE_KEY=/Users/you/git/hermes-voice/backend/certs/scadrial.tailceb58.ts.net.key

# --- Hermes ------------------------------------------------------------------
# Absolute path or command name. Default: looks up `hermes` on PATH.
HERMES_BIN=hermes
# Per-turn timeout in seconds.
HERMES_TIMEOUT_SECONDS=180
# Extra flags appended to every `hermes chat` invocation (space-separated).
# Example: "-t apple_notes,apple_reminders -m anthropic/claude-sonnet-4"
HERMES_EXTRA_ARGS=

# --- STT (speech to text) ----------------------------------------------------
# Provider precedence: openai > groq > elevenlabs > local_whisper > mock.
# Override with STT_PROVIDER if you want to force one.
# Tip: set STT_PROVIDER=elevenlabs to A/B Scribe against OpenAI Whisper
# without removing your OpenAI key.
# STT_PROVIDER=openai      # whisper-1 via OpenAI
# STT_PROVIDER=elevenlabs  # Scribe v1 via ElevenLabs (uses ELEVENLABS_API_KEY)
# STT_PROVIDER=groq        # whisper-large-v3-turbo via Groq

OPENAI_API_KEY=
# Alternate env var name some folks use; either is accepted.
# VOICE_TOOLS_OPENAI_KEY=

GROQ_API_KEY=

# Local faster-whisper (requires `pip install '.[local]'`).
LOCAL_WHISPER_MODEL=base.en
# auto | cpu | cuda | metal
LOCAL_WHISPER_DEVICE=auto

# --- TTS (text to speech) ----------------------------------------------------
# Provider precedence: elevenlabs > openai > local_piper > mock.
# TTS_PROVIDER=elevenlabs

ELEVENLABS_API_KEY=
# Default: Brian (deeper narrator). Replace with any ElevenLabs voice ID.
ELEVENLABS_VOICE_ID=nPczCjzI2devNBz1zQrb
ELEVENLABS_MODEL=eleven_turbo_v2_5

# OpenAI TTS fallback. Voice options: alloy, echo, fable, onyx, nova, shimmer.
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=onyx

# Local Piper (requires `pip install '.[local]'`).
# Download a voice .onnx + .onnx.json from https://huggingface.co/rhasspy/piper-voices
# and point at the .onnx file.
PIPER_VOICE_PATH=
